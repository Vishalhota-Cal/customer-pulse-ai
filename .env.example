# Copy this file to .env and fill in whichever ONE of these you actually have.
# NEVER commit the real .env file -- it's already in .gitignore.

# Use this if you have an Anthropic API key:
ANTHROPIC_API_KEY=your-anthropic-key-here

# Use this instead if you only have an OpenAI API key:
OPENAI_API_KEY=your-openai-key-here
